@model DatabaseSampleDetailsViewModel
@{
    ViewData["Title"] = "詳細";
}

<h2>@ViewData["Title"]</h2>

@* ポイント: TempData["Message"] で子エンティティの CRUD 操作後のフィードバックを表示する *@
@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* ─── 親エンティティ情報 ─── *@
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong><i class="fas fa-database me-1"></i>親エンティティ（ID: @Model.Parent.Id）</strong>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Parent.Id" class="btn btn-sm btn-primary">
                <i class="fas fa-edit me-1"></i>編集
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Parent.Id" class="btn btn-sm btn-danger ms-1">
                <i class="fas fa-trash me-1"></i>削除
            </a>
        </div>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ID</dt>
            <dd class="col-sm-9">@Model.Parent.Id</dd>

            <dt class="col-sm-3">ユーザーID</dt>
            <dd class="col-sm-9">@Model.Parent.ApplicationUserId</dd>

            <dt class="col-sm-3">文字列データ</dt>
            <dd class="col-sm-9">@Model.Parent.StringData</dd>

            <dt class="col-sm-3">数値データ</dt>
            <dd class="col-sm-9">@Model.Parent.IntData</dd>

            <dt class="col-sm-3">BoolData</dt>
            <dd class="col-sm-9">@(Model.Parent.BoolData ? "あり" : "無し")</dd>

            <dt class="col-sm-3">EnumData</dt>
            <dd class="col-sm-9">@Model.Parent.EnumData</dd>

            <dt class="col-sm-3">EnumData2</dt>
            <dd class="col-sm-9">@Model.Parent.EnumData2</dd>

            <dt class="col-sm-3">ファイル</dt>
            <dd class="col-sm-9">@Model.Parent.FileData</dd>

            <dt class="col-sm-3">作成日時</dt>
            <dd class="col-sm-9">@Model.Parent.CreateDate.ToString("yyyy/MM/dd HH:mm:ss")</dd>

            <dt class="col-sm-3">更新日時</dt>
            <dd class="col-sm-9">@Model.Parent.UpdateDate.ToString("yyyy/MM/dd HH:mm:ss")</dd>
        </dl>
    </div>
</div>

@* ─── 子エンティティ一覧 ─── *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        @*
            ポイント: 親子関係のポイント解説
            子エンティティは SumpleEntityID（外部キー）で親 SampleEntity.Id に紐づく
        *@
        <strong>
            <i class="fas fa-list me-1"></i>子エンティティ一覧
            @* ポイント: 子件数をバッジで表示して一目で件数を把握できるようにする *@
            <span class="badge bg-primary ms-1">@Model.Children.Count 件</span>
        </strong>
        @* ポイント: 子の新規追加時は親IDをクエリパラメータで渡してFKを設定できるようにする *@
        <a asp-action="ChildCreate" asp-route-parentId="@Model.Parent.Id" class="btn btn-sm btn-success">
            <i class="fas fa-plus me-1"></i>子エンティティ 追加
        </a>
    </div>
    <div class="card-body">
        @if (!Model.Children.Any())
        {
            <p class="text-muted mb-0">子エンティティはまだ登録されていません。</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped table-hover table-bordered mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>子ID</th>
                            <th>文字列データ</th>
                            <th>数値データ</th>
                            <th>BoolData</th>
                            <th>作成日時</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var child in Model.Children)
                        {
                            <tr>
                                <td>@child.Id</td>
                                <td>@child.StringData</td>
                                <td>@child.IntData</td>
                                <td>@(child.BoolData ? "あり" : "無し")</td>
                                <td>@child.CreateDate.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>
                                    <a asp-action="ChildEdit" asp-route-id="@child.Id" class="btn btn-sm btn-primary">編集</a>
                                    <a asp-action="ChildDelete" asp-route-id="@child.Id" class="btn btn-sm btn-danger ms-1">削除</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-1"></i>一覧に戻る
    </a>
</div>
