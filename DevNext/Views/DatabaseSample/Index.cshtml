@model DatabaseSampleViewModel
@{
    ViewData["Title"] = "DBサンプル一覧";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus me-1"></i>Create New</a>
</p>

<form id="SearchForm" asp-controller="DatabaseSample" asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Page" type="hidden" />
    <input asp-for="Sort" type="hidden" />
    <input asp-for="SortDir" type="hidden" />
    <input asp-for="RecordNum" type="hidden" />
    <input asp-for="PageRead" type="hidden" />

    <div class="card mb-3">
        <div class="card-header">検索条件</div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-3">
                    <label asp-for="Cond.ApplicationUserId" class="form-label">ユーザー</label>
                    <select asp-for="Cond.ApplicationUserId" asp-items="Model.Cond.ApplicationUserIdist" class="form-control">
                        <option value="">全て</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="Cond.StringData" class="form-label">文字列データ</label>
                    <input asp-for="Cond.StringData" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Cond.IntData" class="form-label">数値データ</label>
                    <input asp-for="Cond.IntData" type="number" class="form-control" />
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4">
                    <label class="form-label">BoolData</label>
                    <div>
                        @foreach (var item in Model.Cond.BoolDataSelectList)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio"
                                       name="Cond.BoolData"
                                       id="BoolData_@item.Value"
                                       value="@item.Value"
                                       @(Model.Cond.BoolData?.ToString().ToLower() == item.Value ? "checked" : (string.IsNullOrEmpty(item.Value) && Model.Cond.BoolData == null ? "checked" : "")) />
                                <label class="form-check-label" for="BoolData_@item.Value">@item.Text</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">EnumData</label>
                    <div>
                        @foreach (var item in Model.Cond.EnumDataList)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox"
                                       name="Cond.EnumData"
                                       id="EnumData_@item.Value"
                                       value="@item.Value"
                                       @(Model.Cond.EnumData.Contains(item.Value ?? "") ? "checked" : "") />
                                <label class="form-check-label" for="EnumData_@item.Value">@item.Text</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <label asp-for="Cond.EnumData2" class="form-label">EnumData2</label>
                    <select asp-for="Cond.EnumData2" asp-items="Model.Cond.EnumData2List" class="form-control">
                        <option value="">全て</option>
                    </select>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-md-3">
                    <label asp-for="Cond.Create_start_date" class="form-label"></label>
                    <input asp-for="Cond.Create_start_date" type="date" class="form-control"
                           value="@(Model.Cond.Create_start_date?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Cond.Create_end_date" class="form-label"></label>
                    <input asp-for="Cond.Create_end_date" type="date" class="form-control"
                           value="@(Model.Cond.Create_end_date?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="button" class="btn btn-primary" onclick="funcSearch()">
                <i class="fas fa-search me-1"></i>検索
            </button>
            <button type="button" class="btn btn-secondary ms-1" onclick="funcClear()">
                <i class="fas fa-times me-1"></i>クリア
            </button>
            <a asp-action="ImportFile" class="btn btn-warning ms-1">
                <i class="fas fa-file-import me-1"></i>インポート
            </a>
            <button type="button" class="btn btn-info ms-1" onclick="funcExcelDownload()">
                <i class="fas fa-file-excel me-1"></i>エクセルDL
            </button>
            <button type="button" class="btn btn-danger ms-1" onclick="funcPdfDownload()">
                <i class="fas fa-file-pdf me-1"></i>PDFダウンロード
            </button>
        </div>
    </div>
</form>

<div id="SearchResult">
    @await Html.PartialAsync("_IndexPartial", Model)
</div>

@section Scripts {
    <script>
        function funcSearch() {
            $('#Page').val(1);
            $('#PageRead').val('Resarch');
            submitSearch();
        }

        function funcClear() {
            window.location.href = '@Url.Action("Index")';
        }

        function funcSort(sortColumn) {
            var currentSort = $('#Sort').val();
            var currentDir = $('#SortDir').val();
            if (currentSort === sortColumn) {
                $('#SortDir').val(currentDir === 'ASC' ? 'DESC' : 'ASC');
            } else {
                $('#Sort').val(sortColumn);
                $('#SortDir').val('ASC');
            }
            $('#Page').val(1);
            $('#PageRead').val('Sorting');
            submitSearch();
        }

        function funcRecordNumber(val) {
            $('#RecordNum').val(val);
            $('#Page').val(1);
            $('#PageRead').val('ChangeRecordNum');
            submitSearch();
        }

        function funcPage(page) {
            $('#Page').val(page);
            $('#PageRead').val('Paging');
            submitSearch();
        }

        function funcExcelDownload() {
            $('#Page').val(1);
            var form = $('#SearchForm');
            var action = form.attr('action');
            form.attr('action', '@Url.Action("ExportExcelFile")');
            form.submit();
            form.attr('action', action);
        }

        function funcPdfDownload() {
            $('#Page').val(1);
            var form = $('#SearchForm');
            var action = form.attr('action');
            form.attr('action', '@Url.Action("PdfDownload")');
            form.submit();
            form.attr('action', action);
        }

        function submitSearch() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index")',
                data: $('#SearchForm').serialize(),
                success: function (result) {
                    $('#SearchResult').html(result);
                },
                error: function () {
                    alert('検索中にエラーが発生しました。');
                }
            });
        }
    </script>
}
