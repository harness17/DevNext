@model Site.Entity.FileEntity
@{
    ViewData["Title"] = "ファイル削除確認";
}

<h2>@ViewData["Title"]</h2>

<div class="alert alert-warning">
    <i class="fas fa-exclamation-triangle me-2"></i>
    以下のファイルを削除します。この操作は取り消せません。
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">ファイル名</dt>
            <dd class="col-sm-9">@Model.OriginalFileName</dd>

            <dt class="col-sm-3">サイズ</dt>
            <dd class="col-sm-9">@Model.FileSize.ToString("N0") バイト</dd>

            <dt class="col-sm-3">MIMEタイプ</dt>
            <dd class="col-sm-9">@Model.ContentType</dd>

            <dt class="col-sm-3">説明</dt>
            <dd class="col-sm-9">@(Model.Description ?? "（なし）")</dd>

            <dt class="col-sm-3">アップロード日時</dt>
            <dd class="col-sm-9">@Model.CreateDate.ToString("yyyy/MM/dd HH:mm:ss")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">
        <i class="fas fa-trash me-1"></i>削除する
    </button>
    <a asp-action="Index" class="btn btn-secondary ms-2">
        <i class="fas fa-arrow-left me-1"></i>キャンセル
    </a>
</form>
