@model FileManagementViewModel
@{
    ViewData["Title"] = "ファイル管理";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">ファイルのアップロード・一覧・ダウンロード・削除のサンプルです。</p>

@* ─── アップロードフォーム ──────────────────────────────── *@
<div class="card mb-4">
    <div class="card-header"><i class="fas fa-upload me-1"></i>ファイルアップロード</div>
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row align-items-end g-2">
                <div class="col-md-4">
                    <label class="form-label">ファイル <span class="text-danger">*</span></label>
                    <input type="file" name="UploadFile" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">説明</label>
                    <input type="text" name="Description" class="form-control" maxlength="500"
                           placeholder="ファイルの説明を入力（任意）" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-upload me-1"></i>アップロード
                    </button>
                </div>
            </div>
            <div class="mt-1 text-muted small">
                許可: pdf / xls / xlsx / doc / docx / ppt / pptx / png / jpeg / jpg / gif / txt / csv / zip（最大 10MB）
            </div>
        </form>
    </div>
</div>

@* ─── 検索フォーム ──────────────────────────────────────── *@
<form id="SearchForm" asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Page" type="hidden" />
    <input asp-for="Sort" type="hidden" />
    <input asp-for="SortDir" type="hidden" />
    <input asp-for="RecordNum" type="hidden" />
    <input asp-for="PageRead" type="hidden" />

    <div class="card mb-3">
        <div class="card-header">検索条件</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label asp-for="Cond.OriginalFileName" class="form-label"></label>
                    <input asp-for="Cond.OriginalFileName" class="form-control" placeholder="部分一致" />
                </div>
                <div class="col-md-5">
                    <label asp-for="Cond.Description" class="form-label"></label>
                    <input asp-for="Cond.Description" class="form-control" placeholder="部分一致" />
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="button" class="btn btn-primary" onclick="funcSearch()">
                <i class="fas fa-search me-1"></i>検索
            </button>
            <button type="button" class="btn btn-secondary ms-1" onclick="funcClear()">
                <i class="fas fa-times me-1"></i>クリア
            </button>
        </div>
    </div>
</form>

@* ─── 検索結果（Ajax 差し替えエリア）──────────────────── *@
<div id="SearchResult">
    @await Html.PartialAsync("_IndexPartial", Model)
</div>

@section Scripts {
    <script>
        function funcSearch() {
            $('#Page').val(1);
            $('#PageRead').val('Resarch');
            submitSearch();
        }

        function funcClear() {
            window.location.href = '@Url.Action("Index")';
        }

        function funcSort(sortColumn) {
            var currentSort = $('#Sort').val();
            var currentDir = $('#SortDir').val();
            if (currentSort === sortColumn) {
                $('#SortDir').val(currentDir === 'ASC' ? 'DESC' : 'ASC');
            } else {
                $('#Sort').val(sortColumn);
                $('#SortDir').val('ASC');
            }
            $('#Page').val(1);
            $('#PageRead').val('Sorting');
            submitSearch();
        }

        function funcRecordNumber(val) {
            $('#RecordNum').val(val);
            $('#Page').val(1);
            $('#PageRead').val('ChangeRecordNum');
            submitSearch();
        }

        function funcPage(page) {
            $('#Page').val(page);
            $('#PageRead').val('Paging');
            submitSearch();
        }

        function submitSearch() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index")',
                data: $('#SearchForm').serialize(),
                success: function (result) {
                    $('#SearchResult').html(result);
                },
                error: function () {
                    alert('検索中にエラーが発生しました。');
                }
            });
        }
    </script>
}
