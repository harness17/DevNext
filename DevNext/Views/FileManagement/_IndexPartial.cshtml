@model FileManagementViewModel
@{
    var summary = Model.RowData.Summary;
    var currentPage = summary?.CurrentPage ?? 1;
    var totalRecords = summary?.TotalRecords ?? 0;
    var recoedNumber = Model.Cond.Pager.recoedNumber > 0 ? Model.Cond.Pager.recoedNumber : 10;
    var totalPage = totalRecords > 0 ? (int)Math.Ceiling((double)totalRecords / recoedNumber) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>全 <strong>@totalRecords</strong> 件</div>
    <div class="d-flex align-items-center">
        <span class="me-2">表示件数：</span>
        <select onchange="funcRecordNumber(value)" class="form-select form-select-sm" style="width:auto;">
            @foreach (var item in Model.RecoedNumberList)
            {
                <option value="@item.Value" selected="@(item.Value == Model.RecordNum.ToString())">@item.Text</option>
            }
        </select>
    </div>
</div>

@if (!Model.RowData.rows.Any())
{
    <div class="alert alert-info">データなし</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('OriginalFileName')" class="text-white text-decoration-none">
                            ファイル名
                            @if (Model.Sort == "OriginalFileName")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('FileSize')" class="text-white text-decoration-none">
                            サイズ
                            @if (Model.Sort == "FileSize")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>MIMEタイプ</th>
                    <th>説明</th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('CreateDate')" class="text-white text-decoration-none">
                            アップロード日時
                            @if (Model.Sort == "CreateDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RowData.rows)
                {
                    <tr>
                        <td>
                            <i class="fas fa-file me-1 text-secondary"></i>
                            @row.OriginalFileName
                        </td>
                        <td class="text-end">@FormatFileSize(row.FileSize)</td>
                        <td>@row.ContentType</td>
                        <td>@row.Description</td>
                        <td>@row.CreateDate.ToString("yyyy/MM/dd HH:mm")</td>
                        <td>
                            <a asp-action="Download" asp-route-id="@row.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-download me-1"></i>DL
                            </a>
                            <a asp-action="Delete" asp-route-id="@row.Id" class="btn btn-sm btn-danger ms-1">
                                <i class="fas fa-trash me-1"></i>削除
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ページング *@
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage - 1))">前へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">前へ</span></li>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPage, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@i)">@i</a>
                </li>
            }

            @if (currentPage < totalPage)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage + 1))">次へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">次へ</span></li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted">@currentPage / @totalPage ページ</div>
}

@functions {
    /// <summary>バイト数を人が読みやすい形式にフォーマットする</summary>
    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1024.0 / 1024.0:F1} MB";
    }
}
