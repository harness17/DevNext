@{
    ViewData["Title"] = "ホーム";
}

<div class="text-center">
    <h1 class="display-4">DevNext サンプルアプリ</h1>
    <p class="lead mt-3">ASP.NET Core MVC サンプルプロジェクト</p>
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-database me-2"></i>DBサンプル</h5>
                <p class="card-text">データベースの検索・登録・更新・削除・親子関係CRUDのサンプルです。</p>
                <a asp-controller="DatabaseSample" asp-action="Index" class="btn btn-primary me-2">一覧へ</a>
                <a asp-controller="DatabaseSample" asp-action="MapperUsage" class="btn btn-secondary">MapperUsage</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-layer-group me-2"></i>ビューサンプル</h5>
                <p class="card-text">パーシャルビュー・ソート機能のサンプルです。</p>
                <a asp-controller="ViewSample" asp-action="PartialSample" class="btn btn-primary me-2">PartialSample</a>
                <a asp-controller="ViewSample" asp-action="SortSample" class="btn btn-secondary">SortSample</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-envelope me-2"></i>メール送信サンプル</h5>
                <p class="card-text">Email.cs とテキストテンプレートを使ったメール送信のサンプルです。</p>
                <a asp-controller="MailSample" asp-action="Index" class="btn btn-primary me-2">フォームへ</a>
                <a asp-controller="MailLog" asp-action="Index" class="btn btn-secondary">送信ログ</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-folder-open me-2"></i>ファイル管理</h5>
                <p class="card-text">ファイルのアップロード・ダウンロード・削除のサンプルです。</p>
                <a asp-controller="FileManagement" asp-action="Index" class="btn btn-primary">一覧へ</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-chart-line me-2"></i>ダッシュボード</h5>
                <p class="card-text">Chart.js を使ったグラフ表示と Ajax ポーリングによるリアルタイム更新のサンプルです。</p>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">ダッシュボードへ</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-list-ol me-2"></i>多段階フォーム</h5>
                <p class="card-text">Step1 → Step2 → 確認 → 完了 のウィザード形式フォームのサンプルです。</p>
                <a asp-controller="WizardSample" asp-action="Index" class="btn btn-primary me-2">一覧へ</a>
                <a asp-controller="WizardSample" asp-action="Step1" class="btn btn-secondary">新規登録</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-tasks me-2"></i>承認ワークフロー</h5>
                <p class="card-text">申請の作成・提出・承認・却下を管理する承認ワークフローです。</p>
                <a asp-controller="ApprovalRequest" asp-action="Index" class="btn btn-primary">一覧へ</a>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-calendar-alt me-2"></i>スケジュール</h5>
                <p class="card-text">個人・共有の予定管理と繰り返しスケジュール、参加者招待機能のサンプルです。</p>
                <a asp-controller="Schedule" asp-action="Index" class="btn btn-primary">カレンダーへ</a>
            </div>
        </div>
    </div>
    @* ポイント: Admin ロールのみ表示する管理機能カード *@
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-6 mb-3">
            <div class="card h-100 border-warning">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-users-cog me-2"></i>ユーザー・ロール管理</h5>
                    <p class="card-text">ユーザーの一覧・編集・削除、ロールの付与・剥奪ができます。（Admin限定）</p>
                    <a asp-controller="UserManagement" asp-action="Index" class="btn btn-warning">一覧へ</a>
                </div>
            </div>
        </div>
    }
</div>
