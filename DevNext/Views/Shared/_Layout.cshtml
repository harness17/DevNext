<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DevNext</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">DevNext</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">ホーム</a>
                        </li>
@* サンプル系機能をひとつのドロップダウンに集約 *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" id="sampleDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">サンプル</a>
                            <ul class="dropdown-menu" aria-labelledby="sampleDropdown">
                                <li><h6 class="dropdown-header">DB サンプル</h6></li>
                                <li><a class="dropdown-item" asp-controller="DatabaseSample" asp-action="Index">一覧</a></li>
                                <li><a class="dropdown-item" asp-controller="DatabaseSample" asp-action="BulkCreate">一括登録</a></li>
                                <li><a class="dropdown-item" asp-controller="DatabaseSample" asp-action="MapperUsage">MapperUsage</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">ビューサンプル</h6></li>
                                <li><a class="dropdown-item" asp-controller="ViewSample" asp-action="PartialSample">PartialSample</a></li>
                                <li><a class="dropdown-item" asp-controller="ViewSample" asp-action="SortSample">SortSample</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">メールサンプル</h6></li>
                                <li><a class="dropdown-item" asp-controller="MailSample" asp-action="Index">送信フォーム</a></li>
                                <li><a class="dropdown-item" asp-controller="MailLog" asp-action="Index">送信ログ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="FileManagement" asp-action="Index">ファイル管理</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header">多段階フォーム</h6></li>
                                <li><a class="dropdown-item" asp-controller="WizardSample" asp-action="Index">一覧</a></li>
                                <li><a class="dropdown-item" asp-controller="WizardSample" asp-action="Step1">新規登録</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="ApprovalRequest" asp-action="Index">承認申請</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Schedule" asp-action="Index">スケジュール</a>
                        </li>
                        @* ポイント: Admin ロールのみ表示する管理メニュー *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="UserManagement" asp-action="Index">ユーザー管理</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @* ポイント: 認証済みユーザーのみ通知ベルを表示する *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @await Html.PartialAsync("_NotificationPartial")
                        }
                        @await Html.PartialAsync("_LoginPartial")
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted mt-4 py-3">
        <div class="container">
            &copy; 2026 - DevNext
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* ポイント: _LayoutModalPartial は jQuery を使用するため jQuery 読み込み後に配置する *@
    @await Html.PartialAsync("_LayoutModalPartial")

    @await RenderSectionAsync("Scripts", required: false)

    @* ポイント: 通知ポーリング JS は jQuery 読み込み後に記述する必要があるためここに配置 *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            // ─── 通知ポーリング ──────────────────────────────────────────────
            // ポイント: ダッシュボードと同じ Ajax ポーリング方式（10秒間隔）
            //           ベルアイコンのバッジ表示を定期的に更新する

            function loadNotificationCount() {
                $.get('/Notification/GetUnreadCount', function (data) {
                    if (data.count > 0) {
                        $('#notificationBadge').text(data.count).show();
                    } else {
                        $('#notificationBadge').hide();
                    }
                });
            }

            function loadNotificationList() {
                $.get('/Notification/GetRecent', function (items) {
                    if (!items || items.length === 0) {
                        $('#notificationList').html(
                            '<div class="px-3 py-3 text-muted small text-center">通知はありません</div>'
                        );
                        return;
                    }

                    let html = '';
                    items.forEach(function (item) {
                        // ポイント: 未読は背景色を変えて強調表示する
                        const bgClass = item.isRead ? '' : 'bg-light';
                        const fontClass = item.isRead ? 'text-muted' : 'fw-semibold';
                        const escapedUrl = item.relatedUrl ? item.relatedUrl.replace(/"/g, '&quot;') : '';
                        html += `
                            <a class="dropdown-item notification-item ${bgClass} py-2 border-bottom"
                               href="#" data-id="${item.id}" data-url="${escapedUrl}">
                                <div class="small ${fontClass}">${item.message}</div>
                                <div class="text-muted" style="font-size:0.72rem;">${item.createDate}</div>
                            </a>`;
                    });
                    $('#notificationList').html(html);
                }).fail(function () {
                    $('#notificationList').html(
                        '<div class="px-3 py-2 text-danger small">取得に失敗しました</div>'
                    );
                });
            }

            // ─── ドロップダウン開時に一覧を再取得 ───────────────────────────
            $('#notificationBell').on('show.bs.dropdown', function () {
                loadNotificationList();
            });

            // ─── 通知クリック → 既読 + 遷移 ────────────────────────────────
            $(document).on('click', '.notification-item', function (e) {
                e.preventDefault();
                const id = $(this).data('id');
                const url = $(this).data('url');
                $.ajax({
                    type: 'POST',
                    url: '/Notification/MarkAsRead',
                    contentType: 'application/json',
                    data: JSON.stringify({ id: id }),
                    success: function () {
                        loadNotificationCount();
                        if (url) { window.location.href = url; }
                        else { loadNotificationList(); }
                    }
                });
            });

            // ─── すべて既読ボタン ────────────────────────────────────────────
            $('#markAllReadBtn').on('click', function (e) {
                e.stopPropagation();
                $.post('/Notification/MarkAllAsRead', function () {
                    loadNotificationCount();
                    loadNotificationList();
                });
            });

            // ─── 初回ロード + 10秒ポーリング ────────────────────────────────
            loadNotificationCount();
            setInterval(loadNotificationCount, 10000);
        </script>
    }
</body>
</html>
