@model PartialSampleViewModel
@{
    ViewData["Title"] = "Partial サンプル";
}

<h2>@ViewData["Title"]</h2>
<p>パーシャルビューの使用例です。</p>

@*
    ポイント: パーシャルビューはビューの一部を別ファイルに分離する仕組み
    - 繰り返し使用するHTMLを再利用できる
    - 専用モデルを渡すことで独立したコンポーネントとして扱える
    - @await Html.PartialAsync("パス", モデル) で非同期に読み込む
*@
<form asp-controller="ViewSample" asp-action="PartialSample" method="post">
    @Html.AntiForgeryToken()

    <h4>単体パーシャル (Child)</h4>
    <div class="card mb-4">
        <div class="card-body">
            @*
                ポイント: Model.Child を PartialSampleChildModel として _Child.cshtml に渡す
                パーシャルビューは親ビューのモデルとは独立した型のモデルを受け取れる
                ここでは <table> タグなしでパーシャルを埋め込んでいるため、
                _Child.cshtml の <tr> が直接レンダリングされる
            *@
            @await Html.PartialAsync("PartialSamplePartials/_Child", Model.Child)
        </div>
    </div>

    <h4>リストパーシャル (ChildList)</h4>
    <div class="card mb-4">
        <div class="card-body">
            <table class="table table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>テキスト</th>
                        <th>数値</th>
                        <th>Enum</th>
                    </tr>
                </thead>
                <tbody>
                    @*
                        ポイント: ループ内でパーシャルを呼び出してリストを描画するパターン
                        各行に対して同じ _Child.cshtml を使い回せる
                        インデックス付きの for ループで i を持つことで
                        フォームバインディング用の name 属性（ChildList[0].Text 等）が必要な場合に対応できる
                    *@
                    @for (int i = 0; i < Model.ChildList.Count; i++)
                    {
                        @await Html.PartialAsync("PartialSamplePartials/_Child", Model.ChildList[i])
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">送信</button>
    </div>
</form>

@*
    ポイント: <template> タグは HTML の標準機能で、ページロード時には描画されない
    JavaScript で innerHTML を取得してクローンを作成し、動的に行を追加するために使う
    この方法はサーバー側Razor構文を使えないため、静的な選択肢のみ記述できる
*@
<template id="child-template">
    <tr>
        <td><input type="text" class="form-control" placeholder="テキスト" /></td>
        <td><input type="number" class="form-control" placeholder="数値" /></td>
        <td>
            <select class="form-select">
                <option value="0">選択肢1</option>
                <option value="2">選択肢2</option>
                <option value="3">選択肢3</option>
            </select>
        </td>
    </tr>
</template>
