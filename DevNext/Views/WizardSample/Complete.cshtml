@{
    ViewData["Title"] = "登録完了";
}

<h2>多段階フォームサンプル</h2>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-success">
            <div class="card-body text-center py-5">
                <i class="fas fa-check-circle text-success fa-4x mb-3"></i>
                <h4 class="mb-2">登録が完了しました</h4>
                <p class="text-muted">入力内容がデータベースに保存されました。</p>
                <a asp-action="Step1" class="btn btn-primary mt-2">
                    <i class="fas fa-redo me-1"></i>もう一度入力する
                </a>
            </div>
        </div>
    </div>
</div>
