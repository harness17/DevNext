@model WizardSampleListViewModel
@using Dev.CommonLibrary.Common
@using Site.Common
@{
    var summary       = Model.RowData.Summary;
    var currentPage   = summary?.CurrentPage ?? 1;
    var totalRecords  = summary?.TotalRecords ?? 0;
    var recordNumber  = Model.Cond.Pager.recoedNumber > 0 ? Model.Cond.Pager.recoedNumber : 10;
    var totalPage     = totalRecords > 0 ? (int)Math.Ceiling((double)totalRecords / recordNumber) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        全 <strong>@totalRecords</strong> 件
    </div>
    <div class="d-flex align-items-center">
        <span class="me-2">表示件数：</span>
        <select onchange="funcRecordNumber(value)" class="form-select form-select-sm" style="width:auto;">
            @foreach (var item in Model.RecordNumberList)
            {
                <option value="@item.Value" selected="@(item.Value == Model.RecordNum.ToString())">@item.Text</option>
            }
        </select>
    </div>
</div>

@if (!Model.RowData.rows.Any())
{
    <div class="alert alert-info">データなし</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Name')" class="text-white text-decoration-none">
                            氏名
                            @if (Model.Sort == "Name")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Email')" class="text-white text-decoration-none">
                            メールアドレス
                            @if (Model.Sort == "Email")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>電話番号</th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Subject')" class="text-white text-decoration-none">
                            件名
                            @if (Model.Sort == "Subject")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>カテゴリ</th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('DesiredDate')" class="text-white text-decoration-none">
                            希望対応日
                            @if (Model.Sort == "DesiredDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('CreateDate')" class="text-white text-decoration-none">
                            登録日時
                            @if (Model.Sort == "CreateDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RowData.rows)
                {
                    <tr>
                        <td>@row.Name</td>
                        <td>@row.Email</td>
                        <td>@(row.Phone ?? "-")</td>
                        <td>@row.Subject</td>
                        @* Enum の Display 属性から日本語名を取得して表示する *@
                        <td>@(EnumUtility.GetEnumDisplay<WizardCategory>(row.Category.ToString()))</td>
                        <td>@(row.DesiredDate?.ToString("yyyy/MM/dd") ?? "-")</td>
                        <td>@row.CreateDate.ToString("yyyy/MM/dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage - 1))">前へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">前へ</span>
                </li>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPage, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@i)">@i</a>
                </li>
            }

            @if (currentPage < totalPage)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage + 1))">次へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">次へ</span>
                </li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted">
        @currentPage / @totalPage ページ
    </div>
}
