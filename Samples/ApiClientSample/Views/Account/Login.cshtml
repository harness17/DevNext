@model ApiClientSample.Models.LoginViewModel
@{
    ViewData["Title"] = "ログイン";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">ログイン</h2>
        <p class="text-muted small mb-3">ApiSample のユーザー情報でログインしてください。</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">メールアドレス</label>
                <input asp-for="Email" class="form-control" placeholder="admin1@sample.jp" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">パスワード</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">ログイン</button>
        </form>

        <div class="mt-4 p-3 bg-light rounded small">
            <strong>テストユーザー</strong><br />
            Admin: admin1@sample.jp / Admin1!<br />
            Member: member1@sample.jp / Member1!
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
