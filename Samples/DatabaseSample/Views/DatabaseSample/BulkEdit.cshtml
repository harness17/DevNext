@model DatabaseSampleBulkEditViewModel
@{
    // ポイント: Model.Id の null チェックで新規登録／編集を判定する
    bool isNew = Model.Id == null;
    ViewData["Title"] = isNew ? "一括登録" : "一括編集";
}

<h2>@ViewData["Title"]</h2>
<p class="text-muted">親エンティティと子エンティティをまとめて@(isNew ? "登録" : "編集")します。</p>

<form id="bulkEditForm"
      asp-controller="DatabaseSample"
      asp-action="@(isNew ? "BulkCreate" : "BulkEdit")"
      method="post">
    @Html.AntiForgeryToken()
    @* ポイント: 編集時は親エンティティの Id を hidden で保持して更新対象を特定する *@
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    @* ─── 親エンティティ入力欄 ─── *@
    <div class="card mb-4">
        <div class="card-header"><strong><i class="fas fa-database me-1"></i>親エンティティ</strong></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StringData" class="form-label"></label>
                    <input asp-for="StringData" class="form-control" />
                    <span asp-validation-for="StringData" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="IntData" class="form-label"></label>
                    <input asp-for="IntData" type="number" class="form-control" />
                    <span asp-validation-for="IntData" class="text-danger"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="BoolData" class="form-label d-block"></label>
                    <div class="form-check mt-2">
                        <input asp-for="BoolData" class="form-check-input" />
                        <label asp-for="BoolData" class="form-check-label">あり</label>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="EnumData" class="form-label"></label>
                    <select asp-for="EnumData" asp-items="Model.EnumDataList" class="form-select">
                        <option value="">-- 選択 --</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="EnumData2" class="form-label"></label>
                    <select asp-for="EnumData2" asp-items="Model.EnumData2List" class="form-select"></select>
                </div>
            </div>
        </div>
    </div>

    @* ─── 子エンティティ入力テーブル ─── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="fas fa-list me-1"></i>子エンティティ
                <span id="children-count" class="badge bg-primary ms-1">@Model.Children.Count 件</span>
            </strong>
            @* ポイント: 「行を追加」ボタンで JavaScript により新しい子行をテーブルに追加する *@
            <button type="button" class="btn btn-success btn-sm" onclick="addChildRow()">
                <i class="fas fa-plus me-1"></i>行を追加
            </button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:40%">文字列データ <span class="text-danger">*</span></th>
                            <th style="width:20%">数値データ</th>
                            <th style="width:15%">BoolData</th>
                            <th style="width:15%"></th>
                        </tr>
                    </thead>
                    <tbody id="children-tbody">
                        @* ポイント: 既存の子エンティティを Index を指定してバインドする
                                   Children[0].Id / Children[0].StringData … の形式で MVC がリストに変換する *@
                        @for (int i = 0; i < Model.Children.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="hidden" name="Children[@i].Id" value="@Model.Children[i].Id" />
                                    <input type="text"
                                           name="Children[@i].StringData"
                                           value="@Model.Children[i].StringData"
                                           class="form-control form-control-sm"
                                           required />
                                </td>
                                <td>
                                    <input type="number"
                                           name="Children[@i].IntData"
                                           value="@Model.Children[i].IntData"
                                           class="form-control form-control-sm" />
                                </td>
                                <td class="text-center align-middle">
                                    @* ポイント: value="true" を明示することでチェック時に "true" を送信する
                                               value 未指定だと "on" が送信され BoolModelBinder が失敗するため必須 *@
                                    <input type="checkbox"
                                           name="Children[@i].BoolData"
                                           value="true"
                                           class="form-check-input"
                                           @(Model.Children[i].BoolData ? "checked" : "") />
                                </td>
                                <td class="text-center align-middle">
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="removeChildRow(this)">
                                        <i class="fas fa-times"></i> 削除
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div id="no-children-msg" class="p-3 text-muted @(Model.Children.Any() ? "d-none" : "")">
                子エンティティはありません。「行を追加」で追加できます。
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save me-1"></i>@(isNew ? "登録" : "更新")
        </button>
        @if (isNew)
        {
            <a asp-action="Index" asp-route-returnList="true" class="btn btn-secondary ms-2">一覧に戻る</a>
        }
        else
        {
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">詳細に戻る</a>
        }
    </div>
</form>

@* ─── 子行テンプレート（フォーム外に置くことで POST に含まれない） ─── *@
@* ポイント: __INDEX__ プレースホルダーを JavaScript で実際のインデックスに置換してから tbody に追加する *@
<template id="child-row-template">
    <tr>
        <td>
            <input type="hidden" name="Children[__INDEX__].Id" value="" />
            <input type="text"
                   name="Children[__INDEX__].StringData"
                   value=""
                   class="form-control form-control-sm"
                   required />
        </td>
        <td>
            <input type="number"
                   name="Children[__INDEX__].IntData"
                   value="0"
                   class="form-control form-control-sm" />
        </td>
        <td class="text-center align-middle">
            @* ポイント: value="true" を明示することでチェック時に "true" を送信する *@
            <input type="checkbox"
                   name="Children[__INDEX__].BoolData"
                   value="true"
                   class="form-check-input" />
        </td>
        <td class="text-center align-middle">
            <button type="button"
                    class="btn btn-outline-danger btn-sm"
                    onclick="removeChildRow(this)">
                <i class="fas fa-times"></i> 削除
            </button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ポイント: 新規行追加時のインデックスカウンター
        //           既存行数からスタートして行追加のたびにインクリメントする
        var childIndex = @Model.Children.Count;

        // ─── 行を追加 ───
        function addChildRow() {
            var template = document.getElementById('child-row-template').innerHTML;
            // ポイント: __INDEX__ プレースホルダーを現在のカウンターで一括置換する
            var newRow = template.replace(/__INDEX__/g, childIndex);
            document.getElementById('children-tbody').insertAdjacentHTML('beforeend', newRow);
            childIndex++;
            updateChildrenState();
        }

        // ─── 行を削除 ───
        function removeChildRow(btn) {
            btn.closest('tr').remove();
            updateChildrenState();
        }

        // ─── 件数バッジ・「子なし」メッセージの更新 ───
        function updateChildrenState() {
            var count = document.querySelectorAll('#children-tbody tr').length;
            document.getElementById('children-count').textContent = count + ' 件';
            var noMsg = document.getElementById('no-children-msg');
            noMsg.classList.toggle('d-none', count > 0);
        }

        // ─── サブミット前にインデックスを連番に振り直す ───
        // ポイント: 行削除でインデックスに歯抜けが生じても、ここで 0, 1, 2 … に詰め直すことで
        //           ASP.NET Core MVC のリストバインドが正しく機能する
        document.getElementById('bulkEditForm').addEventListener('submit', function () {
            var rows = document.querySelectorAll('#children-tbody tr');
            rows.forEach(function (row, idx) {
                row.querySelectorAll('input').forEach(function (input) {
                    if (input.name) {
                        input.name = input.name.replace(/Children\[\d+\]/, 'Children[' + idx + ']');
                    }
                });
            });
        });
    </script>
}
