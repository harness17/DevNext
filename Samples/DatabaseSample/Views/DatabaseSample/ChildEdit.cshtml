@model DatabaseSampleChildEditViewModel
@{
    // ポイント: Model.Id の null チェックで新規作成／編集を判定する
    bool isNew = Model.Id == null;
    ViewData["Title"] = isNew ? "子エンティティ 新規追加" : "子エンティティ 編集";
}

<h2>@ViewData["Title"]</h2>

@* ポイント: 親IDを表示してユーザーがどの親に紐づく子を操作しているかを明示する *@
<p class="text-muted">
    <i class="fas fa-database me-1"></i>親エンティティ ID: <strong>@Model.ParentId</strong>
</p>

<div class="row">
    <div class="col-md-6">
        @*
            ポイント: 新規作成と編集で同一ビューを使い回すパターン
            ChildCreate / ChildEdit アクションで処理を分岐させる
        *@
        <form asp-controller="DatabaseSample" asp-action="@(isNew ? "ChildCreate" : "ChildEdit")" method="post">
            @Html.AntiForgeryToken()
            @* ポイント: Id（子ID）と ParentId（親ID）を hidden で保持してFKを確実に引き継ぐ *@
            <input asp-for="Id" type="hidden" />
            <input asp-for="ParentId" type="hidden" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="StringData" class="form-label"></label>
                <input asp-for="StringData" class="form-control" />
                <span asp-validation-for="StringData" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IntData" class="form-label"></label>
                <input asp-for="IntData" type="number" class="form-control" />
                <span asp-validation-for="IntData" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BoolData" class="form-label"></label>
                <div class="form-check">
                    <input asp-for="BoolData" class="form-check-input" />
                    <label asp-for="BoolData" class="form-check-label">あり</label>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i>@(isNew ? "追加" : "更新")
                </button>
                @* ポイント: 子の操作後は親の詳細ページに戻るようにリンクを設定する *@
                <a asp-action="Details" asp-route-id="@Model.ParentId" class="btn btn-secondary ms-2">
                    詳細に戻る
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
