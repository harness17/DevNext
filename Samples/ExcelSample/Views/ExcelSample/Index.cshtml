@model ExcelSampleViewModel
@{
    ViewData["Title"] = "商品一覧";
}

<h2>@ViewData["Title"]</h2>

<div class="row mb-3">
    <div class="col">
        <!-- エクスポートボタン -->
        <a asp-action="Export" class="btn btn-success">
            <i class="fa fa-file-excel"></i> Excelダウンロード
        </a>
    </div>
</div>

<!-- ─────────────────────────────────────────────
     インポートフォーム
     ポイント: enctype="multipart/form-data" を指定しないとファイルが送信されない
───────────────────────────────────────────── -->
<div class="card mb-4">
    <div class="card-header">
        <strong>Excelインポート</strong>
    </div>
    <div class="card-body">
        <form asp-action="Import" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row align-items-end g-2">
                <div class="col-auto">
                    <label class="form-label mb-0">Excelファイル（.xlsx）</label>
                    <input type="file" name="ImportFile" accept=".xlsx" class="form-control" />
                    <span asp-validation-for="ImportFile" class="text-danger"></span>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">インポート</button>
                </div>
            </div>
            <div class="mt-2 text-muted small">
                ※ 1行目はヘッダー行としてスキップされます。列順：商品名 / カテゴリ / 単価（円） / 在庫数
            </div>
        </form>

        <!-- インポート結果 -->
        @if (Model.ImportSuccessCount > 0 || Model.ImportErrors.Count > 0)
        {
            <hr />
            @if (Model.ImportSuccessCount > 0)
            {
                <div class="alert alert-success py-2">
                    <i class="fa fa-check-circle"></i> @Model.ImportSuccessCount 件を登録しました。
                </div>
            }
            @if (Model.ImportErrors.Count > 0)
            {
                <div class="alert alert-warning py-2">
                    <strong>以下の行にエラーがあります（スキップされました）：</strong>
                    <ul class="mb-0 mt-1">
                        @foreach (var err in Model.ImportErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>

<!-- ─────────────────────────────────────────────
     商品一覧テーブル
───────────────────────────────────────────── -->
@if (Model.Rows.Count == 0)
{
    <div class="alert alert-info">データがありません。Excelからインポートしてください。</div>
}
else
{
    <table class="table table-bordered table-hover table-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>商品名</th>
                <th>カテゴリ</th>
                <th class="text-end">単価（円）</th>
                <th class="text-end">在庫数</th>
                <th>登録日時</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Id</td>
                    <td>@row.Name</td>
                    <td>@row.Category</td>
                    <td class="text-end">@row.Price.ToString("N0")</td>
                    <td class="text-end">@row.Quantity.ToString("N0")</td>
                    <td>@row.CreateDate.ToString("yyyy/MM/dd HH:mm")</td>
                    <td>
                        <!-- ポイント: 削除は確認なしを避けるため JS で confirm を挟む -->
                        <form asp-action="Delete" method="post" onsubmit="return confirm('削除してもよいですか？');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@row.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fa fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
