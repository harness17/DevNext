@model MailLogViewModel
@{
    ViewData["Title"] = "メール送信ログ";
}

<h2>@ViewData["Title"]</h2>

<form id="SearchForm" asp-controller="MailLog" asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="Page" type="hidden" />
    <input asp-for="Sort" type="hidden" />
    <input asp-for="SortDir" type="hidden" />
    <input asp-for="RecordNum" type="hidden" />
    <input asp-for="PageRead" type="hidden" />

    <div class="card mb-3">
        <div class="card-header">検索条件</div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-md-3">
                    <label asp-for="Cond.SenderName" class="form-label"></label>
                    <input asp-for="Cond.SenderName" class="form-control" placeholder="部分一致" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Cond.SenderEmail" class="form-label"></label>
                    <input asp-for="Cond.SenderEmail" class="form-control" placeholder="部分一致" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">送信結果</label>
                    <div>
                        @* bool? 型はラジオボタンで「全て / 成功 / 失敗」の3択にする *@
                        @foreach (var item in Model.Cond.IsSuccessList)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio"
                                       name="Cond.IsSuccess"
                                       id="IsSuccess_@item.Value"
                                       value="@item.Value"
                                       @(Model.Cond.IsSuccess?.ToString().ToLower() == item.Value ? "checked" : (string.IsNullOrEmpty(item.Value) && Model.Cond.IsSuccess == null ? "checked" : "")) />
                                <label class="form-check-label" for="IsSuccess_@item.Value">@item.Text</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="row mb-2">
                <div class="col-md-3">
                    <label asp-for="Cond.SentFrom" class="form-label"></label>
                    <input asp-for="Cond.SentFrom" type="date" class="form-control"
                           value="@(Model.Cond.SentFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Cond.SentTo" class="form-label"></label>
                    <input asp-for="Cond.SentTo" type="date" class="form-control"
                           value="@(Model.Cond.SentTo?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>
        </div>
        <div class="card-footer">
            <button type="button" class="btn btn-primary" onclick="funcSearch()">
                <i class="fas fa-search me-1"></i>検索
            </button>
            <button type="button" class="btn btn-secondary ms-1" onclick="funcClear()">
                <i class="fas fa-times me-1"></i>クリア
            </button>
        </div>
    </div>
</form>

<div id="SearchResult">
    @await Html.PartialAsync("_IndexPartial", Model)
</div>

@section Scripts {
    <script>
        function funcSearch() {
            $('#Page').val(1);
            $('#PageRead').val('Resarch');
            submitSearch();
        }

        function funcClear() {
            window.location.href = '@Url.Action("Index")';
        }

        function funcSort(sortColumn) {
            var currentSort = $('#Sort').val();
            var currentDir = $('#SortDir').val();
            if (currentSort === sortColumn) {
                $('#SortDir').val(currentDir === 'ASC' ? 'DESC' : 'ASC');
            } else {
                $('#Sort').val(sortColumn);
                $('#SortDir').val('ASC');
            }
            $('#Page').val(1);
            $('#PageRead').val('Sorting');
            submitSearch();
        }

        function funcRecordNumber(val) {
            $('#RecordNum').val(val);
            $('#Page').val(1);
            $('#PageRead').val('ChangeRecordNum');
            submitSearch();
        }

        function funcPage(page) {
            $('#Page').val(page);
            $('#PageRead').val('Paging');
            submitSearch();
        }

        function submitSearch() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Index")',
                data: $('#SearchForm').serialize(),
                success: function (result) {
                    $('#SearchResult').html(result);
                },
                error: function () {
                    alert('検索中にエラーが発生しました。');
                }
            });
        }
    </script>
}
