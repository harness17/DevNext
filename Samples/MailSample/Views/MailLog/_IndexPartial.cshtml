@model MailLogViewModel
@{
    var summary = Model.RowData.Summary;
    var currentPage = summary?.CurrentPage ?? 1;
    var totalRecords = summary?.TotalRecords ?? 0;
    var recordNumber = Model.Cond.Pager.recoedNumber > 0 ? Model.Cond.Pager.recoedNumber : 20;
    var totalPage = totalRecords > 0 ? (int)Math.Ceiling((double)totalRecords / recordNumber) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        全 <strong>@totalRecords</strong> 件
    </div>
    <div class="d-flex align-items-center">
        <span class="me-2">表示件数：</span>
        <select onchange="funcRecordNumber(value)" class="form-select form-select-sm" style="width:auto;">
            @foreach (var item in Model.RecoedNumberList)
            {
                <option value="@item.Value" selected="@(item.Value == Model.RecordNum.ToString())">@item.Text</option>
            }
        </select>
    </div>
</div>

@if (!Model.RowData.Rows.Any())
{
    <div class="alert alert-info">データなし</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('CreateDate')" class="text-white text-decoration-none">
                            送信日時
                            @if (Model.Sort == "CreateDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('SenderName')" class="text-white text-decoration-none">
                            送信者名
                            @if (Model.Sort == "SenderName")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('SenderEmail')" class="text-white text-decoration-none">
                            送信者メール
                            @if (Model.Sort == "SenderEmail")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Subject')" class="text-white text-decoration-none">
                            件名
                            @if (Model.Sort == "Subject")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('IsSuccess')" class="text-white text-decoration-none">
                            送信結果
                            @if (Model.Sort == "IsSuccess")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>エラー詳細</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RowData.Rows)
                {
                    <tr>
                        <td>@row.CreateDate.ToString("yyyy/MM/dd HH:mm:ss")</td>
                        <td>@row.SenderName</td>
                        <td>@row.SenderEmail</td>
                        <td>@row.Subject</td>
                        <td>
                            @if (row.IsSuccess)
                            {
                                <span class="badge bg-success">成功</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">失敗</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(row.ErrorMessage))
                            {
                                @* エラーメッセージが長い場合はツールチップで全文を表示する *@
                                <span class="text-danger" title="@row.ErrorMessage"
                                      data-bs-toggle="tooltip" data-bs-placement="left">
                                    @(row.ErrorMessage.Length > 30 ? row.ErrorMessage[..30] + "…" : row.ErrorMessage)
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage - 1))">前へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">前へ</span>
                </li>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPage, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@i)">@i</a>
                </li>
            }

            @if (currentPage < totalPage)
            {
                <li class="page-item">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage + 1))">次へ</a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">次へ</span>
                </li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted">
        @currentPage / @totalPage ページ
    </div>
}

@* ツールチップを有効化する *@
<script>
    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
        new bootstrap.Tooltip(el);
    });
</script>
