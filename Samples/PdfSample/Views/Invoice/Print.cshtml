@model InvoiceDetailViewModel
@{
    Layout = "_LayoutPrint";
    ViewData["Title"] = $"請求書_{Model.InvoiceNumber}";
    var total = Model.Items.Sum(x => x.SubTotal);
}

<header class="print-header">
    <div>
        <h1 class="print-title">請求書</h1>
        <div class="invoice-client">@Model.ClientName 御中</div>
    </div>
    <dl class="print-meta">
        <dt>請求書番号</dt>
        <dd>@Model.InvoiceNumber</dd>
        <dt>発行日</dt>
        <dd>@Model.IssueDate.ToString("yyyy/MM/dd")</dd>
        <dt>支払期限</dt>
        <dd>@Model.DueDate.ToString("yyyy/MM/dd")</dd>
        <dt>ステータス</dt>
        <dd>@Model.Status.DisplayName()</dd>
    </dl>
</header>

<table class="invoice-items">
    <thead>
        <tr>
            <th>品目</th>
            <th class="text-end">数量</th>
            <th class="text-end">単価</th>
            <th class="text-end">小計</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Description</td>
                <td class="text-end">@item.Quantity</td>
                <td class="text-end">@item.UnitPrice.ToString("#,0.##")</td>
                <td class="text-end">@item.SubTotal.ToString("#,0.##")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="total-row">
            <th colspan="3" class="text-end">合計金額</th>
            <td class="text-end">@total.ToString("#,0.##") 円</td>
        </tr>
    </tfoot>
</table>

<section class="notes">
    <div class="notes-title">備考</div>
    <div class="notes-body">@(string.IsNullOrWhiteSpace(Model.Notes) ? "なし" : Model.Notes)</div>
</section>
