@model InvoiceViewModel
@{
    var summary = Model.RowData.Summary;
    var currentPage = summary?.CurrentPage ?? 1;
    var totalRecords = summary?.TotalRecords ?? 0;
    var recordNumber = Model.Cond.Pager.recoedNumber > 0 ? Model.Cond.Pager.recoedNumber : 10;
    var totalPage = totalRecords > 0 ? (int)Math.Ceiling((double)totalRecords / recordNumber) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>全 <strong>@totalRecords</strong> 件</div>
    <div class="d-flex align-items-center">
        <span class="me-2">表示件数：</span>
        <select onchange="funcRecordNumber(value)" class="form-select form-select-sm" style="width:auto;">
            @foreach (var item in Model.RecordNumberList)
            {
                <option value="@item.Value" selected="@(item.Value == Model.RecordNum.ToString())">@item.Text</option>
            }
        </select>
    </div>
</div>

@if (!Model.RowData.Rows.Any())
{
    <div class="alert alert-info">データなし</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th><input type="checkbox" onchange="toggleAll(this)" /></th>
                    <th>ID</th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('InvoiceNumber')" class="text-white text-decoration-none">
                            請求書番号
                            @if (Model.Sort == "InvoiceNumber")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('ClientName')" class="text-white text-decoration-none">
                            取引先名
                            @if (Model.Sort == "ClientName")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('IssueDate')" class="text-white text-decoration-none">
                            発行日
                            @if (Model.Sort == "IssueDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('DueDate')" class="text-white text-decoration-none">
                            支払期限
                            @if (Model.Sort == "DueDate")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="javascript:void(0)" onclick="funcSort('Status')" class="text-white text-decoration-none">
                            ステータス
                            @if (Model.Sort == "Status")
                            {
                                <i class="fas fa-sort-@(Model.SortDir == "ASC" ? "up" : "down") ms-1"></i>
                            }
                        </a>
                    </th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.RowData.Rows)
                {
                    <tr>
                        <td><input type="checkbox" name="SelectedIds" value="@row.Id" /></td>
                        <td>@row.Id</td>
                        <td>@row.InvoiceNumber</td>
                        <td>@row.ClientName</td>
                        <td>@row.IssueDate.ToString("yyyy/MM/dd")</td>
                        <td>@row.DueDate.ToString("yyyy/MM/dd")</td>
                        <td>@row.Status.DisplayName()</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@row.Id" class="btn btn-sm btn-info">詳細</a>
                            <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-sm btn-primary">編集</a>
                            <a asp-action="Delete" asp-route-id="@row.Id" class="btn btn-sm btn-danger">削除</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (currentPage > 1)
            {
                <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage - 1))">前へ</a></li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">前へ</span></li>
            }

            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPage, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="funcPage(@i)">@i</a>
                </li>
            }

            @if (currentPage < totalPage)
            {
                <li class="page-item"><a class="page-link" href="javascript:void(0)" onclick="funcPage(@(currentPage + 1))">次へ</a></li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">次へ</span></li>
            }
        </ul>
    </nav>
    <div class="text-center text-muted">@currentPage / @totalPage ページ</div>
}
