@model WizardStep2ViewModel
@{
    ViewData["Title"] = "多段階フォーム - Step 2: 詳細情報";
}

<h2>多段階フォームサンプル</h2>

@await Html.PartialAsync("_ProgressBar", 2)

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <strong>Step 2</strong> — 詳細情報を入力してください
            </div>
            <div class="card-body">
                <form asp-action="Step2" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label"></label>
                        <span class="text-danger">*</span>
                        <input asp-for="Subject" class="form-control" placeholder="件名を入力してください" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label"></label>
                        <span class="text-danger">*</span>
                        <select asp-for="Category" asp-items="Model.CategoryList" class="form-select"></select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label"></label>
                        <span class="text-danger">*</span>
                        <textarea asp-for="Content" class="form-control" rows="5"
                                  placeholder="内容を入力してください（最大2000文字）"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DesiredDate" class="form-label"></label>
                        <input asp-for="DesiredDate" type="date" class="form-control"
                               value="@(Model.DesiredDate?.ToString("yyyy-MM-dd"))" />
                        <span asp-validation-for="DesiredDate" class="text-danger"></span>
                        <div class="form-text">任意。対応を希望する日付があれば入力してください。</div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Step1" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>戻る
                        </a>
                        <button type="submit" class="btn btn-primary">
                            次へ <i class="fas fa-arrow-right ms-1"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
