@* ウィザード進捗バー
   使用方法: @await Html.PartialAsync("_ProgressBar", 2)  ← 現在のステップ番号を渡す *@
@{
    int currentStep = (int)Model;
    var steps = new[] { "基本情報", "詳細情報", "確認" };
}

<div class="d-flex align-items-center mb-4">
    @for (int i = 1; i <= steps.Length; i++)
    {
        bool isCompleted = i < currentStep;
        bool isCurrent   = i == currentStep;

        <div class="d-flex align-items-center flex-grow-1">
            @* ステップ番号と名称 *@
            <div class="text-center" style="min-width: 80px;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center
                            @(isCurrent ? "bg-primary text-white" : isCompleted ? "bg-success text-white" : "bg-secondary text-white")"
                     style="width:36px; height:36px; font-weight:bold;">
                    @if (isCompleted)
                    {
                        <i class="fas fa-check"></i>
                    }
                    else
                    {
                        @i
                    }
                </div>
                <div class="small mt-1 @(isCurrent ? "fw-bold" : "")">@steps[i - 1]</div>
            </div>

            @* ステップ間の接続線（最後のステップには不要）*@
            @if (i < steps.Length)
            {
                <div class="flex-grow-1 border-top border-2 mx-1
                            @(isCompleted ? "border-success" : "border-secondary")"
                     style="margin-bottom: 22px;"></div>
            }
        </div>
    }
</div>
